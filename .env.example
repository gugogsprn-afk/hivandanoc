# Скопируйте этот файл как .env и заполните своими данными:
#   copy .env.example .env

# Порт сайта (как в СМОТРЕТЬ.bat)
PORT=8765

# === ПОЧТА (куда приходят заявки) ===
# Ваш тестовый email — сюда будут приходить письма с форм
NOTIFY_EMAIL=ваш-email@gmail.com

# SMTP для отправки (пример Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ваш-email@gmail.com
SMTP_PASS=ваш-пароль-приложения-gmail

# От кого показывается письмо
MAIL_FROM="CHIC Healthy Spine <ваш-email@gmail.com>"

# === TELEGRAM БОТ ===
# Токен от @BotFather (команда /newbot)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHI...

# ID чата — ваш личный или группы (см. КАК-НАСТРОИТЬ-УВЕДОМЛЕНИЯ.txt)
TELEGRAM_CHAT_ID=123456789
