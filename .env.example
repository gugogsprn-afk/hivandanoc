# Copy to .env and fill in values:
#   cp .env.example .env

# ─── Server ───────────────────────────────────────────────────────
PORT=9876
HOST=127.0.0.1
NODE_ENV=production

# Public URLs (used in sitemap, emails, CORS)
PUBLIC_SITE_URL=https://healthyspinedoc.com
ADMIN_SITE_URL=https://admin.healthyspinedoc.com
API_SITE_URL=https://api.healthyspinedoc.com

# ─── CMS / Auth ───────────────────────────────────────────────────
# REQUIRED in production — generate: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRES=30d

# First admin user (created on first seed only)
CMS_ADMIN_EMAIL=admin@healthyspinedoc.com
CMS_ADMIN_PASSWORD=ChangeMe2026!

# SMM specialist — homepage, media, blog content (role: manager)
# Created/updated automatically on server start from these values
CMS_SMM_EMAIL=smm@healthyspinedoc.com
CMS_SMM_PASSWORD=change-this-smm-password
CMS_SMM_NAME=SMM Specialist

# SQLite database path (default: data/cms/cms.db)
# Production — use a directory OUTSIDE the deploy folder so uploads never vanish:
CMS_DATA_DIR=/var/lib/hivandanoc-cms
# CMS_DB_PATH=/var/lib/hivandanoc-cms/cms.db

# Set false to skip auto-seed on startup
CMS_AUTO_SEED=true

# Max upload size in MB
CMS_MAX_UPLOAD_MB=10

# Clinic email (contacts page + mail icon in footer/sidebar)
CONTACT_EMAIL=info@healthyspine.am
CONTACT_PHONE=+374 (10) 00-00-00
CONTACT_ADDRESS=Yerevan, Margaryan 6/2
# Optional — per language (footer + contacts page); fallback is CONTACT_ADDRESS
CONTACT_ADDRESS_HY=Երևան, Մարգարյան 6/2
CONTACT_ADDRESS_RU=г. Ереван, ул. Маргаряна 6/2
CONTACT_ADDRESS_EN=Yerevan, Margaryan 6/2
CONTACT_EMERGENCY=103

# Social media (footer + right sidebar)
SOCIAL_FACEBOOK=https://www.facebook.com/HealthySpineCHIC
SOCIAL_INSTAGRAM=https://www.instagram.com/healthyspinechic
SOCIAL_TIKTOK=https://www.tiktok.com/@healthyspineclinic

# Footer developer credit (bottom right)
DEVELOPER_NAME=DEWEBAM.COM
DEVELOPER_URL=https://dewebam.com

# ─── Email notifications ──────────────────────────────────────────
NOTIFY_EMAIL=your-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Առողջ ողնաշար <your-email@gmail.com>"

# ─── Telegram notifications ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
